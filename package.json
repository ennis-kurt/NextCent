{
  "name": "personal-accountant-ai",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "dev:api": "cd apps/api && python3 -m uvicorn app.main:app --reload",
    "test:api": "cd apps/api && python3 -m pytest"
  }
}
